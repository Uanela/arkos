{{#if (eq validation.type "zod")}}
import { z } from 'zod';

const CreatePermissionForRoleDto = z.object({
  resource: z.string().min(1, 'Resource is required'),
  action: z.string().default('View'),
  description: z.string().optional(),
});

const CreateAuthRoleDto = z.object({
  name: z.string().min(1, 'Role name is required'),
  description: z.string().optional(),
  permissions: z.array(CreatePermissionForRoleDto).optional().default([]),
});

export default CreateAuthRoleDto;
{{#if typescript}}
export type CreateAuthRoleDtoType = z.infer<typeof CreateAuthRoleDto>;
{{/if}}
{{/if}}
{{#if (eq validation.type "class-validator")}}
import { IsString, IsNotEmpty, IsOptional, IsArray, ValidateNested } from 'class-validator';
import { Type, Transform } from 'class-transformer';
import 'reflect-metadata';

class CreatePermissionForRoleDto {
  @IsString()
  @IsNotEmpty({ message: 'Resource is required' })
  resource!: string;

  @IsString()
  @Transform(({ value }) => value || 'View')
  action: string = 'View';

  @IsOptional()
  @IsString()
  @Transform(({ value }) => value)
  description?: string;
}

export default class CreateAuthRoleDto {
  @IsString()
  @IsNotEmpty({ message: 'Role name is required' })
  name!: string;

  @IsOptional()
  @IsString()
  description?: string;

  @IsOptional()
  @IsArray()
  @ValidateNested({ each: true })
  @Type(() => CreatePermissionForRoleDto)
  @Transform(({ value }) => value || [])
  permissions: CreatePermissionForRoleDto[] = [];
}
{{/if}}
