{{#if (eq validation.type "zod")}}
import { z } from 'zod';

const UpdatePermissionForRoleDto = z.object({
  id: z.string().optional(),
  resource: z.string().min(1, "Resource is required"),
  action: z.string(),
  description: z.string().optional(),
  apiAction: z.enum(["connect", "delete", "create", "update"]).optional(),
});

const UpdateAuthRoleDto = z.object({
  name: z.string().min(1, "Role name is required"),
  description: z.string().optional(),
  permissions: z.array(UpdatePermissionForRoleDto).optional().default([]),
});

export default UpdateAuthRoleDto;
{{#if typescript}}
export type UpdateAuthRoleDtoType = z.infer<typeof UpdateAuthRoleDto>;
{{/if}}
{{/if}}
{{#if (eq validation.type "class-validator")}}
import { IsString, IsNotEmpty, IsOptional, IsArray, ValidateNested } from 'class-validator';
import { Type, Transform } from 'class-transformer';
import 'reflect-metadata';

export enum ApiAction {
  connect = 'connect',
  delete = 'delete',
  create = 'create',
  update = 'update'
}

class UpdatePermissionForRoleDto {
  @IsOptional()
  @IsString()
  id?: string;

  @IsString()
  @IsNotEmpty({ message: 'Resource is required' })
  resource!: string;

  @IsString()
  @IsNotEmpty()
  action!: string;

  @IsOptional()
  @IsString()
  @Transform(({ value }) => value)
  description?: string;

  @IsOptional()
  @IsString()
  apiAction?: ApiAction;
}

export default class UpdateAuthRoleDto {
  @IsString()
  @IsNotEmpty({ message: 'Role name is required' })
  name!: string;

  @IsOptional()
  @IsString()
  description?: string;

  @IsOptional()
  @IsArray()
  @ValidateNested({ each: true })
  @Type(() => UpdatePermissionForRoleDto)
  @Transform(({ value }) => value || [])
  permissions?: UpdatePermissionForRoleDto[] = [];
}
{{/if}}
