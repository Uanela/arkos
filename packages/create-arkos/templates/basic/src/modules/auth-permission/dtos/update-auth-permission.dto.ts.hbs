{{#if (eq validation.type "zod")}}
import { z } from 'zod';

const UpdateAuthPermissionDto = z.object({
  resource: z.string().optional(),
  action: z.string().optional(),
  description: z.string().optional(),
});

export default UpdateAuthPermissionDto;
{{#if typescript}}
export type UpdateAuthPermissionDtoType = z.infer<typeof UpdateAuthPermissionDto>;
{{/if}}
{{/if}}
{{#if (eq validation.type "class-validator")}}
import { IsString, IsOptional } from 'class-validator';
import { Transform } from 'class-transformer';
import 'reflect-metadata';

export default class UpdateAuthPermissionDto {
  @IsOptional()
  @IsString()
  resource?: string;

  @IsOptional()
  @IsString()
  @Transform(({ value }) => value)
  action?: string;

  @IsOptional()
  @IsString()
  description?: string;
}
{{/if}}
