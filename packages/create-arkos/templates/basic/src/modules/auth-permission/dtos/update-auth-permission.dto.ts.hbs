import { IsString, IsOptional, IsEnum } from 'class-validator';
import { Transform } from 'class-transformer';
import 'reflect-metadata'

export default class UpdateAuthPermissionDto {
  @IsOptional()
  @IsString()
  resource?: string;

  @IsOptional()
  @IsString()
  @Transform(({ value }) => String(value))
  action?: string
}
