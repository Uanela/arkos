{{#if (eq validation.type "zod")}}
import { z } from "zod";

const SignupDto = z.object({
  {{authentication.usernameField}}: z.string().min(1, "{{authentication.usernameField}} is required"),
  password: z.string().min(8, "Password must be at least 8 characters long"),
});

export default SignupDto;
{{#if typescript}}
export type SignupDtoType = z.infer<typeof SignupDto>;
{{/if}}
{{/if}}
{{#if (eq validation.type "class-validator")}}
import { IsString, MinLength, IsNotEmpty } from 'class-validator';
import "reflect-metadata";

export default class SignupDto {
  @IsString()
  @IsNotEmpty({ message: '{{authentication.usernameField}} is required' })
  {{authentication.usernameField}}!: string;

  @IsString()
  @MinLength(8, { message: 'Password must be at least 8 characters long' })
  password!: string;
}
{{/if}}
