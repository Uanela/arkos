{
  "compilerOptions": {
    "target": "ES6",
    "module": "Node16",
    "moduleResolution": "node16",
    "rootDir": ".",
    "strict": true,
    "sourceMap": true,
    "inlineSources": true,
    "removeComments": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "arkos.config.ts",
    "src/modules/post/dtos/create-post.dto.tsa"
  ],
  "exclude": [
    "node_modules",
    ".build",
    "src/**/__tests__/**",
    "src/**/*.test.ts"
  ]
}
