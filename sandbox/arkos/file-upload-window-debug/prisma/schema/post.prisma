type PostTag {
  name     String
  slug     String
  color    String?
  featured Boolean @default(false)
}

model Post {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  views     Int
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  userId2   String
  user2     User      @relation(fields: [userId2], references: [id], name: "posttouser2")
  mainTag   PostTag
  tags      PostTag[]
}
